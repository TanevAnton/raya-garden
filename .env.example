# Formspree endpoint that receives /contact form submissions.
# When configuring the Formspree form, set the destination email to:
#   hotel@svetagora.bg
# Sign up at https://formspree.io, create a new form, paste the URL here.
# Example: https://formspree.io/f/xnqjrwzd
VITE_FORMSPREE_ENDPOINT=

# Sanity CMS — where the editable content lives.
# Get the projectId from https://www.sanity.io/manage → your project → API.
# The dataset is usually "production".
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Write token used ONLY by scripts/migrate-to-sanity.mjs (server-side).
# Do NOT prefix with VITE_ — it must stay out of the client bundle.
# Create at https://www.sanity.io/manage → your project → API → Tokens
# Permissions: Editor (or higher).
SANITY_WRITE_TOKEN=
